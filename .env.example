# Whisper model size: tiny | base | small | medium | large
# Smaller = faster but less accurate. "base" is a good default.
WHISPER_MODEL_SIZE=base

# Comma-separated list of allowed frontend origins (for CORS)
# Add your Lovable app URL here once deployed
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Max audio file upload size in MB
MAX_FILE_SIZE_MB=50

# Run local for dev if Port 8000 is still occupied by the old process. Kill it
# lsof -ti:8000 | xargs kill -9
# python run.py